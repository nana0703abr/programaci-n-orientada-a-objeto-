class Estudiante:
    def __init__(self, nombre, edad, calificacion):
        """Constructor para inicializar los atributos del estudiante."""
        self.nombre = nombre
        self.edad = edad
        self.calificacion = calificacion

    def verificar_estado(self):
        """Determina si el estudiante aprobó o reprobó."""
        if self.calificacion >= 60:
            return "Aprobado"
        else:
            return "Reprobado"

    def mostrar_informacion(self):
        """Muestra los detalles del estudiante de forma organizada."""
        estado = self.verificar_estado()
        print(f"--- Ficha del Estudiante ---")
        print(f"Nombre: {self.nombre}")
        print(f"Edad:   {self.edad} años")
        print(f"Nota:   {self.calificacion}")
        print(f"Estado: {estado}")
        print("-" * 28)

# --- Ejemplo de aplicación en el aula ---

# Creamos un par de instancias (objetos) de la clase Estudiante
estudiante1 = Estudiante("Ana García", 20, 85)
estudiante2 = Estudiante("Luis Pérez", 22, 45)

# Ejecutamos los métodos
estudiante1.mostrar_informacion()
estudiante2.mostrar_informacion()







EJERCIO 3class Producto:
    def __init__(self, nombre, precio, stock):
        self.nombre = nombre
        self.precio = precio
        self.stock = stock

    def verificar_disponibilidad(self, cantidad):
        return self.stock >= cantidad

    def vender(self, cantidad):
        if self.verificar_disponibilidad(cantidad):
            self.stock -= cantidad
            print(f"Venta exitosa: Se vendieron {cantidad} unidades de {self.nombre}.")
        else:
            print(f"Error: No hay suficiente stock de {self.nombre} para vender {cantidad} unidades.")

    def reabastecer(self, cantidad):
        self.stock += cantidad
        print(f"Reabastecimiento: Se han añadido {cantidad} unidades. Nuevo stock: {self.stock}.")

# --- Ejecución de las operaciones solicitadas ---

