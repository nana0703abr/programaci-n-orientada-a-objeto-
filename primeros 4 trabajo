class Libro:
    def __init__(self, titulo, autor, paginas):
        """Constructor para inicializar los atributos del libro"""
        self.titulo = titulo
        self.autor = autor
        self.paginas = paginas

    def mostrar_informacion(self):
        """Método para imprimir los detalles del libro"""
        print(f"--- Información del Libro ---")
        print(f"Título: {self.titulo}")
        print(f"Autor: {self.autor}")
        print(f"Número de páginas: {self.paginas}")
        print("-----------------------------")

    def actualizar_paginas(self, nuevas_paginas):
        """Método para modificar el número de páginas"""
        if nuevas_paginas > 0:
            self.paginas = nuevas_paginas
            print(f"¡Páginas actualizadas con éxito a {nuevas_paginas}!")
        else:
            print("Error: El número de páginas debe ser mayor a cero.")

# --- Ejemplo de uso ---

# 1. Crear un objeto (instancia) de la clase Libro
mi_libro = Libro("Cien años de soledad", "Gabriel García Márquez", 496)

# 2. Mostrar la información inicial
mi_libro.mostrar_informacion()

# 3. Actualizar el número de páginas
mi_libro.actualizar_paginas(550)

# 4. Mostrar la información actualizada
mi_libro.mostrar_informacion()





